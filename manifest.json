{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "version": "8.1.0",
  "description": "__MSG_extensionDescription__",

  "icons": {
    "24": "icons/undoclosetab-24.png",
    "32": "icons/undoclosetab-32.png",
    "48": "icons/undoclosetab-48.png"
  },

  "background": {
    "scripts": [
      "utils/storage.js",
      "tabhandling.js",
      "background.js"
    ]
  },

  "browser_action": {
    "default_icon": {
      "24": "icons/undoclosetab-24.png",
      "32": "icons/undoclosetab-32.png"
    },
    "default_title": "__MSG_extensionName__",
    "default_popup": "popup.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "permissions": [
    "contextMenus",
    "tabs",
    "sessions",
    "storage",
    "windows"
  ],

  "default_locale": "en"
}
